include ~/dotfiles/sway/keybinds.conf
include ~/dotfiles/sway/colors.conf
include ~/dotfiles/sway/window_rules.conf

font pango:FiraCode Regular 10


exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway
# auto start applications
exec xrandr --auto
exec --no-startup-id dex-autostart --autostart --environment sway
input type:keyboard {
    xkb_layout "us,bg"
    xkb_variant ",phonetic"
    xkb_options "grp:alt_shift_toggle,ctrl:nocaps"
} 
bar {
    position top
    # Keep in mind that the current directory of this config file is $HOME
    status_command while ~/dotfiles/sway/bar.sh; do sleep 1; done
    colors {
        statusline #6c7086
        background #11111b
        active_workspace #a6e3a1 #a6e3a1 #a6e3a1
        focused_workspace #a6e3a1 #a6e3a1 #1e1e2e
    }
    tray {
      icon_theme Adwaita
      tray_output *
    }
    font pango:MesloLGS Nerd Font Mono 10
}

exec --no-startup-id /usr/lib/xfce-polkit/xfce-polkit
# exec --no-startup-id killall dockercompose || true; bash ~/dotfiles/scripts/docker-compose.bash &

exec --no-startup-id dunst 
exec --no-startup-id xset s 300 0 
exec --no-startup-id autotiling
exec --no-startup-id grim
#use the command below when using the tv 
#xrandr --output HDMI-1-0 --auto --right-of eDP-1

client.focused          $green   $green $green $green $green 
client.focused_inactive $overlay1 $overlay1 $overlay1 $overlay1 $overlay1  
client.unfocused        $overlay2 $overlay2 $overlay2 $overlay2 $overlay2
client.urgent           $red $red $red $red $red 
client.placeholder      #00000000 #00000000 #00000000 #00000000 #00000000

output * bg /home/xeliotrop/wallpapers/greenmountain.jpg fill
